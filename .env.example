# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=blackout
POSTGRES_PASSWORD=change-me-strong-password

# ── JWT ── generate: openssl rand -hex 64 ─────────────────────────────────────
JWT_SECRET=change-me-use-openssl-rand-hex-64

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://your-vps-ip

# ── External APIs ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
