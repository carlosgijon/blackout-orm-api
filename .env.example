# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by docker-compose to create the postgres container
POSTGRES_USER=blackout
POSTGRES_PASSWORD=change-me-strong-password

# ── NestJS ────────────────────────────────────────────────────────────────────
# DATABASE_URL is built automatically inside docker-compose from the vars above.
# Only needed if running the app outside Docker:
# DATABASE_URL=postgresql://blackout:change-me@localhost:5432/blackout_orm

# JWT — generate a strong secret: openssl rand -hex 64
JWT_SECRET=change-me-use-openssl-rand-hex-64
JWT_EXPIRES_IN=7d

PORT=3001
