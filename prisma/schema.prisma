generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Core ────────────────────────────────────────────────────────────────────

model Band {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?  // base64 data URL
  createdAt DateTime @default(now()) @map("created_at")

  users          User[]
  userBands      UserBand[]
  settings       Setting[]
  librarySongs   LibrarySong[]
  playlists      Playlist[]
  bandMembers    BandMember[]
  microphones    Microphone[]
  instruments    Instrument[]
  amplifiers     Amplifier[]
  paEquipment    PaEquipment[]
  venues         Venue[]
  gigs           Gig[]
  calendarEvents CalendarEvent[]
  transactions   Transaction[]
  wishListItems  WishListItem[]
  merchItems     MerchItem[]
  rehearsals     Rehearsal[]
  voteSessions   VoteSession[]

  @@map("bands")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  displayName  String?  @map("display_name")
  passwordHash String   @map("password_hash")
  // "superadmin" | "admin" | "member"
  role         String   @default("member")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  bandId String? @map("band_id")
  band   Band?   @relation(fields: [bandId], references: [id])

  userBands UserBand[]

  @@map("users")
}

model UserBand {
  id     String @id @default(uuid())
  userId String @map("user_id")
  bandId String @map("band_id")
  // "admin" | "member"
  role   String @default("member")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@unique([userId, bandId])
  @@map("user_bands")
}

// ── Settings ────────────────────────────────────────────────────────────────

model Setting {
  id     String @id @default(uuid())
  bandId String @map("band_id")
  key    String
  value  String

  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@unique([bandId, key])
  @@map("settings")
}

// ── Songs & Playlists ───────────────────────────────────────────────────────

model LibrarySong {
  id        String  @id @default(uuid())
  bandId    String  @map("band_id")
  title     String
  artist    String
  album     String?
  duration  Int?    // seconds
  tempo     Int?    // BPM
  style     String?
  notes     String?
  startNote String? @map("start_note") // e.g. "Em", "A#"
  endNote   String? @map("end_note")   // e.g. "G", "Db"

  band           Band            @relation(fields: [bandId], references: [id], onDelete: Cascade)
  playlistSongs  PlaylistSong[]
  rehearsalSongs RehearsalSong[]

  @@map("library_songs")
}

model Playlist {
  id          String   @id @default(uuid())
  bandId      String   @map("band_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  band         Band           @relation(fields: [bandId], references: [id], onDelete: Cascade)
  songs        PlaylistSong[]
  gigs         Gig[]
  voteSessions VoteSession[]

  @@map("playlists")
}

model PlaylistSong {
  id           String  @id @default(uuid())
  playlistId   String  @map("playlist_id")
  songId       String? @map("song_id")
  position     Int
  // "song" | "event"
  type         String? @default("song")
  title        String?
  setlistName  String? @map("setlist_name")
  joinWithNext Boolean @default(false) @map("join_with_next")

  playlist Playlist     @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     LibrarySong? @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@map("playlist_songs")
}

// ── Equipment ───────────────────────────────────────────────────────────────

model BandMember {
  id            String  @id @default(uuid())
  bandId        String  @map("band_id")
  name          String
  // JSON array of MemberRole: "vocalist"|"guitarist"|"bassist"|"drummer"|"keyboardist"|"other"
  roles         String  @default("[]")
  // StagePosition enum stored as string
  stagePosition String? @map("stage_position")
  vocalMicId    String? @map("vocal_mic_id")
  notes         String?
  sortOrder     Int     @default(0) @map("sort_order")

  band           Band            @relation(fields: [bandId], references: [id], onDelete: Cascade)
  instruments    Instrument[]
  amplifiers     Amplifier[]
  calendarEvents CalendarEvent[]

  @@map("band_members")
}

model Microphone {
  id             String  @id @default(uuid())
  bandId         String  @map("band_id")
  name           String
  brand          String?
  model          String?
  // MicType: "dynamic" | "condenser" | "ribbon"
  type           String
  // PolarPattern: "cardioid" | "supercardioid" | "hypercardioid" | "omnidirectional" | "figure-8"
  polarPattern   String? @map("polar_pattern")
  phantomPower   Boolean @default(false) @map("phantom_power")
  // MonoStereo: "mono" | "stereo"
  monoStereo     String  @default("mono") @map("mono_stereo")
  notes          String?
  // MicUsage: "instrument"|"vocal"|"drums-overhead"|"drums-snare"|"drums-kick"|"drums-pack"|"ambient"
  usage          String?
  // MicAssignmentType: "member"|"amplifier"|"instrument"
  assignedToType String? @map("assigned_to_type")
  assignedToId   String? @map("assigned_to_id")

  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@map("microphones")
}

model Instrument {
  id           String  @id @default(uuid())
  bandId       String  @map("band_id")
  memberId     String? @map("member_id")
  name         String
  // InstrumentType: "guitar"|"bass"|"drums"|"keyboard"|"other"
  type         String
  brand        String?
  model        String?
  // InstrumentRouting: "amp"|"di"|"mesa"
  routing      String
  ampId        String? @map("amp_id")
  // MonoStereo: "mono"|"stereo"
  monoStereo   String? @map("mono_stereo")
  channelOrder Int     @default(0) @map("channel_order")
  notes        String?

  band   Band        @relation(fields: [bandId], references: [id], onDelete: Cascade)
  member BandMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@map("instruments")
}

model Amplifier {
  id            String  @id @default(uuid())
  bandId        String  @map("band_id")
  memberId      String? @map("member_id")
  name          String
  // AmpType: "guitar"|"bass"|"keyboard"
  type          String
  brand         String?
  model         String?
  wattage       Int?
  // AmpRouting: "mic"|"di"|"mesa"
  routing       String
  // MonoStereo: "mono"|"stereo"
  monoStereo    String? @map("mono_stereo")
  // StagePosition enum stored as string
  stagePosition String? @map("stage_position")
  notes         String?
  cabinetBrand  String? @map("cabinet_brand")
  speakerBrand  String? @map("speaker_brand")
  speakerModel  String? @map("speaker_model")
  // SpeakerConfig: "1x12"|"2x12"|"4x12"|etc.
  speakerConfig String? @map("speaker_config")

  band   Band        @relation(fields: [bandId], references: [id], onDelete: Cascade)
  member BandMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@map("amplifiers")
}

model PaEquipment {
  id          String  @id @default(uuid())
  bandId      String  @map("band_id")
  // PaCategory: "console"|"main-speaker"|"subwoofer"|"monitor"|"di-box"|"power-amp"|"other"
  category    String
  name        String
  brand       String?
  model       String?
  quantity    Int     @default(1)
  channels    Int?
  auxSends    Int?    @map("aux_sends")
  wattage     Int?
  notes       String?
  // MonitorType: "speaker"|"iem"
  monitorType String? @map("monitor_type")
  iemWireless Boolean @default(false) @map("iem_wireless")

  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@map("pa_equipment")
}

// ── Venues & Gigs ───────────────────────────────────────────────────────────

model Venue {
  id           String   @id @default(uuid())
  bandId       String   @map("band_id")
  name         String
  city         String?
  address      String?
  website      String?
  capacity     Int?
  bookingName  String?  @map("booking_name")
  bookingEmail String?  @map("booking_email")
  bookingPhone String?  @map("booking_phone")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  band Band  @relation(fields: [bandId], references: [id], onDelete: Cascade)
  gigs Gig[]

  @@map("venues")
}

model Gig {
  id             String   @id @default(uuid())
  bandId         String   @map("band_id")
  venueId        String?  @map("venue_id")
  setlistId      String?  @map("setlist_id")
  title          String
  date           String?
  time           String?
  // GigStatus: "lead"|"contacted"|"negotiating"|"hold"|"confirmed"|"played"|"cancelled"
  status         String   @default("lead")
  pay            String?
  loadInTime     String?  @map("load_in_time")
  soundcheckTime String?  @map("soundcheck_time")
  setTime        String?  @map("set_time")
  notes          String?
  attendance     Int?
  followUpDate   String?  @map("follow_up_date")
  followUpNote   String?  @map("follow_up_note")
  createdAt      DateTime @default(now()) @map("created_at")

  band         Band           @relation(fields: [bandId], references: [id], onDelete: Cascade)
  venue        Venue?         @relation(fields: [venueId], references: [id], onDelete: SetNull)
  setlist      Playlist?      @relation(fields: [setlistId], references: [id], onDelete: SetNull)
  contacts     GigContact[]
  checklists   GigChecklist[]
  transactions Transaction[]

  @@map("gigs")
}

model GigContact {
  id          String   @id @default(uuid())
  gigId       String   @map("gig_id")
  date        String
  // GigContactType: "call"|"email"|"meeting"|"message"|"other"
  contactType String   @map("contact_type")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  gig Gig @relation(fields: [gigId], references: [id], onDelete: Cascade)

  @@map("gig_contacts")
}

// ── Calendar ────────────────────────────────────────────────────────────────

model CalendarEvent {
  id        String   @id @default(uuid())
  bandId    String   @map("band_id")
  memberId  String?  @map("member_id")
  // CalendarEventType: "rehearsal"|"unavailable"|"other"
  type      String
  title     String
  date      String
  endDate   String?  @map("end_date")
  allDay    Boolean  @default(true) @map("all_day")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  band   Band        @relation(fields: [bandId], references: [id], onDelete: Cascade)
  member BandMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@map("calendar_events")
}

// ── Checklists ──────────────────────────────────────────────────────────────

model GigChecklist {
  id        String   @id @default(uuid())
  gigId     String   @map("gig_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  gig   Gig             @relation(fields: [gigId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@map("gig_checklists")
}

model ChecklistItem {
  id          String  @id @default(uuid())
  checklistId String  @map("checklist_id")
  // ChecklistCategory: "equipo"|"logistica"|"documentos"|"otro"
  category    String  @default("otro")
  text        String
  done        Boolean @default(false)
  sortOrder   Int     @default(0) @map("sort_order")

  checklist GigChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// ── Finance ─────────────────────────────────────────────────────────────────

model Transaction {
  id          String   @id @default(uuid())
  bandId      String   @map("band_id")
  // "income" | "expense"
  type        String
  // income: "gig"|"merch_sales"|"streaming"|"teaching"|"sponsorship"|"other"
  // expense: "equipment"|"travel"|"accommodation"|"recording"|"marketing"|"rehearsal"|"merch_production"|"venue"|"other"
  category    String
  amount      Float
  date        String   // YYYY-MM-DD
  description String?
  gigId       String?  @map("gig_id")
  createdAt   DateTime @default(now()) @map("created_at")

  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)
  gig  Gig? @relation(fields: [gigId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model WishListItem {
  id             String   @id @default(uuid())
  bandId         String   @map("band_id")
  name           String
  // "instrument"|"equipment"|"merch"|"studio"|"other"
  category       String
  estimatedPrice Float?   @map("estimated_price")
  // "low"|"medium"|"high"
  priority       String   @default("medium")
  notes          String?
  purchased      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@map("wish_list_items")
}

// ── Rehearsals ──────────────────────────────────────────────────────────────

model Rehearsal {
  id        String          @id @default(uuid())
  bandId    String          @map("band_id")
  date      String          // YYYY-MM-DD
  notes     String?
  createdAt DateTime        @default(now()) @map("created_at")

  band  Band            @relation(fields: [bandId], references: [id], onDelete: Cascade)
  songs RehearsalSong[]

  @@map("rehearsals")
}

model RehearsalSong {
  id          String    @id @default(uuid())
  rehearsalId String    @map("rehearsal_id")
  songId      String    @map("song_id")
  notes       String?
  rating      Int?      // 1–5

  rehearsal Rehearsal   @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  song      LibrarySong @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@map("rehearsal_songs")
}

// ── Merch ────────────────────────────────────────────────────────────────────

model MerchItem {
  id             String   @id @default(uuid())
  bandId         String   @map("band_id")
  name           String
  // "t-shirt"|"hoodie"|"vinyl"|"cd"|"poster"|"sticker"|"hat"|"patch"|"other"
  type           String
  productionCost Float    @map("production_cost")
  batchSize      Int      @default(50) @map("batch_size")
  sellingPrice   Float    @map("selling_price")
  fixedCosts     Float    @default(0) @map("fixed_costs")
  stock          Int      @default(0)
  hasSizes       Boolean  @default(false) @map("has_sizes")
  stockSizes     Json?    @map("stock_sizes")   // {"XS":0,"S":5,"M":10,"L":8,"XL":3,"XXL":1}
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@map("merch_items")
}

// ── Setlist Voting ───────────────────────────────────────────────────────────

model VoteSession {
  id         String   @id @default(uuid())
  bandId     String   @map("band_id")
  playlistId String   @map("playlist_id")
  title      String
  // "open" | "closed"
  status     String   @default("open")
  createdAt  DateTime @default(now()) @map("created_at")

  band     Band        @relation(fields: [bandId], references: [id], onDelete: Cascade)
  playlist Playlist    @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  votes    Vote[]

  @@map("vote_sessions")
}

model Vote {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  voterName  String   @map("voter_name")
  orderedIds String   @map("ordered_ids") // JSON array of playlist_song ids
  createdAt  DateTime @default(now()) @map("created_at")

  session VoteSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, voterName])
  @@map("votes")
}
